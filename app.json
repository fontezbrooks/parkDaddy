{
  "expo": {
    "name": "parkDaddy",
    "slug": "parkDaddy",
    "owner": "carlhiggins",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "parkdaddy",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f9f9fb"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.parkdaddy.app",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f9f9fb"
      },
      "package": "com.parkdaddy.app",
      "versionCode": 2,
      "privacy": "unlisted"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#000666"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f5628031-e6e3-4626-8c64-99ea028ac854"
      }
    }
  }
}
