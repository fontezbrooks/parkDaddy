{
  "expo": {
    "name": "parkDaddy",
    "slug": "parkDaddy",
    "owner": "carlhiggins",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "parkdaddy",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f9f9fb"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.parkdaddy.app",
      "buildNumber": "15",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Use Face ID to quickly sign in to parkDaddy",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.776685094975-annpj8aq71bkn2toc4qprv87m6epa8eh"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "parkdaddy"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f9f9fb"
      },
      "package": "com.parkdaddy.app",
      "versionCode": 2
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#000666"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "parkdaddy",
          "organization": "appdaddystudios"
        }
      ],
      "@sentry/react-native"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f5628031-e6e3-4626-8c64-99ea028ac854"
      },
      "EXPO_PUBLIC_CLERK_GOOGLE_IOS_URL_SCHEME": "com.googleusercontent.apps.776685094975-annpj8aq71bkn2toc4qprv87m6epa8eh"
    }
  }
}
